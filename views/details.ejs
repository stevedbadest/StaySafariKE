<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title><%= item.name %> | StaySafariKE</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { font-family: 'Segoe UI', sans-serif; margin: 0; background: #f4f4f4; color: #333; }
        .nav { padding: 15px 10%; background: #005f73; color: white; display: flex; align-items: center; }
        .nav a { color: white; text-decoration: none; font-weight: bold; }
        .hero-img { width: 100%; height: 500px; object-fit: cover; }
        .content { padding: 40px 10%; display: grid; grid-template-columns: 2fr 1fr; gap: 40px; max-width: 1300px; margin: 0 auto; }
        .info-box { background: white; padding: 30px; border-radius: 20px; box-shadow: 0 5px 15px rgba(0,0,0,0.05); }
        .price-card { background: white; padding: 30px; border-radius: 20px; height: fit-content; text-align: center; border: 2px solid #ee9b00; position: sticky; top: 20px; }
        .book-wa { display: block; background: #25D366; color: white; padding: 15px; text-decoration: none; border-radius: 12px; font-weight: bold; margin-top: 20px; transition: 0.3s; }
        .book-wa:hover { background: #128C7E; }
        h1 { margin-top: 0; color: #005f73; font-size: 2.2rem; }
        .amenities { display: flex; gap: 20px; margin: 25px 0; flex-wrap: wrap; }
        .amenity-item { text-align: center; color: #555; font-size: 0.8rem; background: #f8f9fa; padding: 10px; border-radius: 10px; min-width: 60px; }
        .amenity-item i { display: block; font-size: 1.5rem; color: #005f73; margin-bottom: 5px; }
        .review-card { border-left: 4px solid #ee9b00; background: #fffcf5; padding: 15px; margin-bottom: 10px; border-radius: 5px; }
        .review-user { font-weight: bold; color: #005f73; margin-bottom: 5px; display: block; }
    </style>
</head>
<body>
    <div class="nav"><a href="/"><i class="fas fa-arrow-left"></i> Back to Explore</a></div>
    <img src="<%= item.img %>" class="hero-img">
    <div class="content">
        <div class="info-box">
            <h1><%= item.name %></h1>
            <p style="color: #666;"><i class="fas fa-map-marker-alt"></i> <%= item.loc %></p>
            
            <div class="amenities">
                <% if (item.amenities && item.amenities.length > 0) { %>
                    <% item.amenities.forEach(icon => { %>
                        <div class="amenity-item">
                            <i class="fas fa-<%= icon %>"></i>
                            <span><%= icon.replace('-', ' ') %></span>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p style="color: #999;">Standard amenities included.</p>
                <% } %>
            </div>

            <hr>
            <h3>About this <%= item.type %></h3>
            <p style="line-height: 1.8;"><%= item.desc %></p>

            <h3 style="margin-top: 40px;">Guest Reviews</h3>
            <% if(item.reviews && item.reviews.length > 0) { %>
                <% item.reviews.forEach(review => { %>
                    <div class="review-card">
                        <span class="review-user"><%= review.user %></span>
                        "<%= review.text %>"
                    </div>
                <% }); %>
            <% } else { %>
                <p style="color: #999;">No reviews yet. Be the first to book!</p>
            <% } %>
        </div>

        <div class="price-card">
            <p>Daily Rate</p>
            <h2 style="font-size: 2.2rem; margin: 10px 0;">KES <%= item.price.toLocaleString() %></h2>
            <a href="https://wa.me/254700686722?text=Hello%20StaySafari,%20I'm%20ready%20to%20book%20the%20<%= item.name %>" class="book-wa">
                <i class="fab fa-whatsapp"></i> Confirm Booking
            </a>
        </div>
    </div>
</body>
</html>