<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StaySafariKE | Premium Malindi Stays & Cars</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root { 
            --safari-teal: #005f73; 
            --safari-dark: #004d5e;
            --safari-gold: #ee9b00; 
            --whatsapp-green: #25D366; 
            --bg-light: #f8f9fa; 
        }
        
        body { 
            font-family: 'Segoe UI', sans-serif; 
            margin: 0; 
            background: var(--bg-light); 
            color: #333; 
            display: flex; 
            flex-direction: column; 
            min-height: 100vh; 
        }

        /* Top Navigation */
        .top-nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 10%;
            background: var(--safari-dark);
            color: white;
            position: sticky;
            top: 0;
            z-index: 1000;
        }
        .top-nav a {
            color: white;
            text-decoration: none;
            font-weight: bold;
            margin-left: 20px;
            font-size: 0.9rem;
        }
        .logo-text { font-weight: 800; font-size: 1.2rem; letter-spacing: 1px; }

        /* HERO SECTION WITH IMAGE */
        header { 
            position: relative;
            background: url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=1600'); 
            background-size: cover;
            background-position: center;
            color: white; 
            padding: 120px 10% 140px; 
            text-align: center;
            border-bottom: 5px solid var(--safari-gold);
        }

        /* Dark tint over the image to make text readable */
        header::before {
            content: "";
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.45); 
            z-index: 1;
        }

        header h1, header p { position: relative; z-index: 2; margin: 0; }
        header h1 { font-size: 3.5rem; text-shadow: 2px 2px 15px rgba(0,0,0,0.6); }
        header p { font-size: 1.2rem; margin-top: 10px; opacity: 0.9; }

        /* SEARCH BAR OVERLAPPING HERO */
        .search-container { 
            width: 90%; 
            max-width: 850px; 
            margin: -40px auto 0; 
            position: relative; 
            z-index: 10; 
        }
        .search-form { 
            background: white; 
            padding: 8px; 
            display: flex; 
            border-radius: 60px; 
            box-shadow: 0 20px 40px rgba(0,0,0,0.15); 
        }
        .search-form input { border: none; padding: 15px 30px; outline: none; flex: 1; font-size: 1.1rem; border-radius: 60px; }
        .search-form button { background: var(--safari-gold); color: white; border: none; padding: 15px 40px; border-radius: 50px; font-weight: bold; cursor: pointer; transition: 0.3s; }
        .search-form button:hover { background: #d48a00; }

        /* FILTER CHIPS */
        .filter-bar { display: flex; justify-content: center; gap: 15px; margin: 40px 0 20px; flex-wrap: wrap; }
        .filter-chip { padding: 12px 28px; background: white; border: 2px solid var(--safari-teal); color: var(--safari-teal); border-radius: 30px; text-decoration: none; font-weight: bold; display: flex; align-items: center; gap: 10px; transition: 0.3s; }
        .filter-chip:hover { background: var(--safari-teal); color: white; }

        .container { padding: 20px 10% 80px; max-width: 1400px; margin: 0 auto; flex: 1; }

        /* GRID */
        .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 35px; }
        @media (max-width: 1100px) { .grid { grid-template-columns: repeat(2, 1fr); } }
        @media (max-width: 768px) { 
            .grid { grid-template-columns: 1fr; } 
            header h1 { font-size: 2.2rem; }
        }

        /* CARDS */
        .card { 
            background: white; border-radius: 20px; overflow: hidden; 
            box-shadow: 0 8px 20px rgba(0,0,0,0.05); transition: 0.3s; 
            display: flex; flex-direction: column; border: 1px solid #efefef; cursor: pointer;
        }
        .card:hover { transform: translateY(-10px); box-shadow: 0 15px 35px rgba(0,0,0,0.1); }
        .card-img { height: 220px; position: relative; }
        .card-img img { width: 100%; height: 100%; object-fit: cover; }
        .badge { position: absolute; top: 15px; left: 15px; background: white; padding: 6px 14px; border-radius: 20px; font-size: 0.7rem; font-weight: 800; color: var(--safari-teal); text-transform: uppercase; }

        .card-body { padding: 22px; flex-grow: 1; }
        .card-body h3 { margin: 0; font-size: 1.3rem; }
        .location { color: #666; font-size: 0.9rem; margin: 8px 0; }
        .rating { color: #008009; font-weight: bold; font-size: 0.85rem; }

        .card-footer { padding: 18px 22px; background: #fafafa; border-top: 1px solid #eee; display: flex; justify-content: space-between; align-items: center; }
        .price { font-size: 1.25rem; font-weight: 800; }
        .book-btn { background: var(--whatsapp-green); color: white; padding: 10px 20px; border-radius: 12px; font-size: 0.85rem; font-weight: bold; }

        /* Floating Buttons */
        .floating-wa { position: fixed; bottom: 30px; right: 30px; background: var(--whatsapp-green); color: white; width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 30px; box-shadow: 0 5px 20px rgba(0,0,0,0.2); z-index: 100; text-decoration: none; transition: 0.3s; }
        .floating-call { position: fixed; bottom: 105px; right: 30px; background: var(--safari-teal); color: white; width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 25px; box-shadow: 0 5px 20px rgba(0,0,0,0.2); z-index: 100; text-decoration: none; transition: 0.3s; }
        .floating-wa:hover, .floating-call:hover { transform: scale(1.1); }

        footer { background: #111; color: #888; padding: 50px 10%; text-align: center; margin-top: auto; }
        .admin-link { color: #444; text-decoration: none; font-size: 0.7rem; display: block; margin-top: 20px; }
    </style>
</head>
<body>

    <nav class="top-nav">
        <div class="logo-text">STAYSAFARIKE</div>
        <div>
            <a href="/">Home</a>
            <a href="/about">About Us</a>
        </div>
    </nav>

    <header>
        <h1>Find Your Coastal Escape</h1>
        <p>Premium Malindi Stays & Reliable Rides</p>
    </header>
    
    <div class="search-container">
        <form action="/" method="GET" class="search-form">
            <input type="text" name="q" placeholder="Search Villa, Prado, or Location..." autocomplete="off">
            <button type="submit">Explore Now</button>
        </form>
    </div>

    <div class="filter-bar">
        <a href="/?q=all" class="filter-chip"><i class="fas fa-th-large"></i> All</a>
        <a href="/?q=Stay" class="filter-chip"><i class="fas fa-hotel"></i> Stays</a>
        <a href="/?q=Car" class="filter-chip"><i class="fas fa-car-side"></i> Cars</a>
    </div>

    <div class="container">
        <div class="grid">
            <% if (listings.length > 0) { %>
                <% listings.forEach(item => { %>
                    <div class="card" onclick="window.location.href='/listing/<%= item.id %>'">
                        <div class="card-img">
                            <img src="<%= item.img %>" alt="<%= item.name %>">
                            <span class="badge"><%= item.type %></span>
                        </div>
                        <div class="card-body">
                            <h3><%= item.name %></h3>
                            <p class="location"><i class="fas fa-location-dot"></i> <%= item.loc %></p>
                            <div class="rating">★ Verified Safari Choice</div>
                        </div>
                        <div class="card-footer">
                            <div class="price">KES <%= item.price.toLocaleString() %><small>/day</small></div>
                            <span class="book-btn">Book Now</span>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div style="grid-column: 1/-1; text-align: center; padding: 60px;">
                    <h2>No results found for your search.</h2>
                    <a href="/?q=all" style="color: var(--safari-teal); font-weight: bold;">Browse all inventory</a>
                </div>
            <% } %>
        </div>
    </div>

    <a href="tel:+254700686722" class="floating-call"><i class="fas fa-phone"></i></a>
    <a href="https://wa.me/254700686722" class="floating-wa" target="_blank"><i class="fab fa-whatsapp"></i></a>

    <footer>
        <p><b>StaySafariKE</b> &copy; 2026. Malindi, Kenya.</p>
        <p>Premium Stays | Reliable Car Hire | Coastal Tours</p>
        <a href="/admin" class="admin-link">Staff Login</a>
    </footer>

</body>
</html>